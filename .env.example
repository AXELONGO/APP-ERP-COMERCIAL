GOOGLE_CREDENTIALS="tu_service_account_json_aqui"
SPREADSHEET_ID="tu_id_de_google_sheets_aqui"

# GMAIL OAUTH (scope mínimo: gmail.send)
GMAIL_CLIENT_ID="tu_client_id_oauth_web"
GMAIL_CLIENT_SECRET="tu_client_secret_oauth_web"
GMAIL_REDIRECT_URI="http://localhost:3001/api/auth/gmail/callback"
GMAIL_FROM_ADDRESS="demiansoberanes7@gmail.com"
GMAIL_FROM_NAME="ERP LUMARK"
GMAIL_MAX_RECIPIENTS_PER_CAMPAIGN=500
GMAIL_DAILY_RECIPIENT_LIMIT=500
GMAIL_SEND_DELAY_MS=100

# DRIVE OAUTH (opcional; puede reutilizar las credenciales GMAIL)
DRIVE_CLIENT_ID="tu_client_id_oauth_web"
DRIVE_CLIENT_SECRET="tu_client_secret_oauth_web"
DRIVE_REDIRECT_URI="http://localhost:3001/api/auth/google/callback"

# CONFIGURACIÓN DE CALENDLY
CALENDLY_TOKEN="tu_token_de_calendly_aqui"

# NOTIFICACIONES
SLACK_TOKEN="xoxb-tu-token-de-slack"
NOTIFICATION_EMAIL="tu_correo_de_notificaciones@gmail.com"
SMTP_PASS="tu_contraseña_de_aplicacion_gmail"

# N8N WEBHOOKS
N8N_INFORMATION_WEBHOOK_URL="https://chatbot-n8n.or7bqd.easypanel.host/webhook/information"
N8N_BUGS_WEBHOOK_URL="https://n8n.tu-dominio.com/webhook/BUGS"
N8N_CITAS_WEBHOOK_URL="https://n8n.tu-dominio.com/webhook/citas"
N8N_TAREAS_WEBHOOK_URL="https://n8n.tu-dominio.com/webhook/TAREAS"
N8N_PROYECTOS_WEBHOOK_URL="https://n8n.tu-dominio.com/webhook/PROYECTOS"
N8N_PROSPECTOS_WEBHOOK_URL="https://n8n.tu-dominio.com/webhook/PROSPECTOS"

# ENTORNO
PORT=3000
NODE_ENV=development

# GOOGLE AUTH
GOOGLE_CLIENT_ID="tu_client_id_aqui"
JWT_SECRET="un_string_super_secreto_y_largo"

# WHITE-LABELING
APP_NAME="LUMARK"
APP_LOGO="https://www.tulink.com/wp-content/uploads/2024/09/Logo-Lumark.png"

# ── ESCALABILIDAD / CACHÉ ────────────────────────────────────
# TTL de caché en segundos (default: 120s = 2 minutos)
CACHE_TTL=120
# Periodo de verificación de expiración en segundos
CACHE_CHECK_PERIOD=240
# URL de Redis (opcional). Si se configura, la caché se distribuye entre workers
# REDIS_URL="redis://localhost:6379"

# ── CLUSTER / BALANCE DE CARGAS ─────────────────────────────
# Activar clustering (true/false). Útil para servidores multi-core.
CLUSTER_ENABLED=false
# Número de workers (0 = auto, usa todos los CPUs disponibles)
CLUSTER_WORKERS=0

# ── RATE LIMITING ────────────────────────────────────────────
# Ventana de tiempo en ms (default: 15 minutos)
RATE_LIMIT_WINDOW_MS=900000
# Máximo de requests por IP en la ventana
# RATE_LIMIT_MAX=200

# ── GOOGLE SHEETS ────────────────────────────────────────────
# Máximo de requests concurrentes a Google Sheets
GOOGLE_SHEETS_RATE_LIMIT=10
